{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "actions": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "default": {
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "key"
                    },
                    "ctrl": {
                      "type": "boolean"
                    },
                    "alt": {
                      "type": "boolean"
                    },
                    "shift": {
                      "type": "boolean"
                    },
                    "meta": {
                      "type": "boolean"
                    },
                    "code": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "type",
                    "ctrl",
                    "alt",
                    "shift",
                    "meta",
                    "code"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "mouse"
                    },
                    "ctrl": {
                      "type": "boolean"
                    },
                    "alt": {
                      "type": "boolean"
                    },
                    "shift": {
                      "type": "boolean"
                    },
                    "meta": {
                      "type": "boolean"
                    },
                    "mouse_button": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    }
                  },
                  "required": [
                    "type",
                    "ctrl",
                    "alt",
                    "shift",
                    "meta",
                    "mouse_button"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
