{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The app name"
    },
    "actions": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name": {
            "description": "Override the humanized input name",
            "type": "string"
          },
          "default": {
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "key"
                    },
                    "alt": {
                      "type": "boolean",
                      "description": "If the binding uses the Alt key"
                    },
                    "shift": {
                      "type": "boolean",
                      "description": "If the binding uses the Shift key"
                    },
                    "ctrl": {
                      "type": "boolean",
                      "description": "If the binding uses the Ctrl key"
                    },
                    "meta": {
                      "type": "boolean",
                      "description": "If the binding uses the Meta (Windows/Command/Super) key"
                    },
                    "name": {
                      "type": "string",
                      "description": "The browser `KeyboardEvent.code` value that corresponds with the binding"
                    }
                  },
                  "required": [
                    "type",
                    "alt",
                    "shift",
                    "ctrl",
                    "meta",
                    "name"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "mouse"
                    },
                    "alt": {
                      "type": "boolean",
                      "description": "If the binding uses the Alt key"
                    },
                    "shift": {
                      "type": "boolean",
                      "description": "If the binding uses the Shift key"
                    },
                    "ctrl": {
                      "type": "boolean",
                      "description": "If the binding uses the Ctrl key"
                    },
                    "meta": {
                      "type": "boolean",
                      "description": "If the binding uses the Meta (Windows/Command/Super) key"
                    },
                    "index": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991,
                      "description": "The browser `MouseEvent.button` value that corresponds with the binding"
                    }
                  },
                  "required": [
                    "type",
                    "alt",
                    "shift",
                    "ctrl",
                    "meta",
                    "index"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "mouse_wheel"
                    },
                    "alt": {
                      "type": "boolean",
                      "description": "If the binding uses the Alt key"
                    },
                    "shift": {
                      "type": "boolean",
                      "description": "If the binding uses the Shift key"
                    },
                    "ctrl": {
                      "type": "boolean",
                      "description": "If the binding uses the Ctrl key"
                    },
                    "meta": {
                      "type": "boolean",
                      "description": "If the binding uses the Meta (Windows/Command/Super) key"
                    },
                    "direction": {
                      "type": "string",
                      "enum": [
                        "up",
                        "down",
                        "left",
                        "right"
                      ]
                    }
                  },
                  "required": [
                    "type",
                    "alt",
                    "shift",
                    "ctrl",
                    "meta",
                    "direction"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "joypad_button"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "South",
                        "East",
                        "North",
                        "West",
                        "C",
                        "Z",
                        "LeftTrigger",
                        "LeftTrigger2",
                        "RightTrigger",
                        "RightTrigger2",
                        "Select",
                        "Start",
                        "Mode",
                        "LeftThumb",
                        "RightThumb",
                        "DPadUp",
                        "DPadDown",
                        "DPadLeft",
                        "DPadRight",
                        "Unknown"
                      ]
                    }
                  },
                  "required": [
                    "type",
                    "name"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "joypad_axis"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "LeftStickX",
                        "LeftStickY",
                        "LeftZ",
                        "RightStickX",
                        "RightStickY",
                        "RightZ",
                        "DPadX",
                        "DPadY",
                        "Unknown"
                      ]
                    },
                    "direction": {
                      "anyOf": [
                        {
                          "type": "number",
                          "const": -1
                        },
                        {
                          "type": "number",
                          "const": 1
                        }
                      ],
                      "description": "Negative is left for X and down for Y; positive is the opposite."
                    }
                  },
                  "required": [
                    "type",
                    "name",
                    "direction"
                  ],
                  "additionalProperties": false
                }
              ]
            },
            "description": "The default set of bindings for the action"
          }
        },
        "required": [
          "default"
        ],
        "additionalProperties": false
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "actions"
  ],
  "additionalProperties": false
}